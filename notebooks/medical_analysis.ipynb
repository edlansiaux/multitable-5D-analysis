      "source": [
        "# Analyse Médicale avec MT5D\n",
        "\n",
        "Ce notebook démontre l'utilisation du framework MT5D pour l'analyse de données médicales multitable."
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 1. Installation et Importation"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 1,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Si nécessaire, installer le package mt5d\n",
        "# !pip install mt5d-framework\n",
        "\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "import torch\n",
        "import matplotlib.pyplot as plt\n",
        "import seaborn as sns\n",
        "\n",
        "from mt5d import MT5DPipeline, DimensionalProfiler\n",
        "from mt5d.core.hypergraph import RelationalHypergraphBuilder\n",
        "from mt5d.models.embeddings import PentE\n",
        "from mt5d.models.architectures import RelationalHypergraphTransformer\n",
        "\n",
        "sns.set_style(\"whitegrid\")"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 2. Chargement des Données\n",
        "\n",
        "Nous allons créer un jeu de données synthétique pour simuler des données médicales."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 2,
      "metadata": {},
      "outputs": [
        {
          "name": "stdout",
          "output_type": "stream",
          "text": [
            "Patients: 1000\n",
            "Diagnostics: 5000\n",
            "Mesures de laboratoire: 20000\n"
          ]
        }
      ],
      "source": [
        "def generate_medical_data(n_patients=1000, n_diagnoses=5000, n_labs=20000):\n",
        "    \"\"\"Génère des données médicales synthétiques.\"\"\"\n",
        "    \n",
        "    # Patients\n",
        "    patients = pd.DataFrame({\n",
        "        'patient_id': range(n_patients),\n",
        "        'age': np.random.randint(18, 90, n_patients),\n",
        "        'gender': np.random.choice(['M', 'F'], n_patients),\n",
        "        'admission_date': pd.date_range('2020-01-01', periods=n_patients, freq='D')\n",
        "    })\n",
        "    \n",
        "    # Diagnostics (codes ICD-10)\n",
        "    icd_codes = [f'I{i:02d}' for i in range(1, 100)] + [f'J{i:02d}' for i in range(1, 100)]\n",
        "    diagnoses = pd.DataFrame({\n",
        "        'diagnosis_id': range(n_diagnoses),\n",
        "        'patient_id': np.random.choice(patients['patient_id'], n_diagnoses),\n",
        "        'code': np.random.choice(icd_codes, n_diagnoses),\n",
        "        'date': pd.date_range('2020-01-01', periods=n_diagnoses, freq='H')\n",
        "    })\n",
        "    \n",
        "    # Mesures de laboratoire\n",
        "    lab_parameters = ['K+', 'Na+', 'Cl-', 'Glucose', 'Creatinine', 'Urea', 'Bilirubin']\n",
        "    labs = pd.DataFrame({\n",
        "        'lab_id': range(n_labs),\n",
        "        'patient_id': np.random.choice(patients['patient_id'], n_labs),\n",
        "        'parameter': np.random.choice(lab_parameters, n_labs),\n",
        "        'value': np.random.normal(0, 1, n_labs),\n",
        "        'timestamp': pd.date_range('2020-01-01', periods=n_labs, freq='T')\n",
        "    })\n",
        "    \n",
        "    return {\n",
        "        'patients': patients,\n",
        "        'diagnoses': diagnoses,\n",
        "        'labs': labs\n",
        "    }\n",
        "\n",
        "# Génération des données\n",
        "data = generate_medical_data()\n",
        "\n",
        "print(f\"Patients: {len(data['patients'])}\")\n",
        "print(f\"Diagnostics: {len(data['diagnoses'])}\")\n",
        "print(f\"Mesures de laboratoire: {len(data['labs'])}\")"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 3. Définition des Relations\n",
        "\n",
        "Nous définissons les relations entre les tables."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 3,
      "metadata": {},
      "outputs": [],
      "source": [
        "relationships = [\n",
        "    ('diagnoses', 'patient_id', 'patients', 'patient_id', 'has_diagnosis'),\n",
        "    ('labs', 'patient_id', 'patients', 'patient_id', 'has_lab')\n",
        "]"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 4. Profilage 5D\n",
        "\n",
        "Analysons les dimensions de nos données."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 4,
      "metadata": {},
      "outputs": [
        {
          "name": "stdout",
          "output_type": "stream",
          "text": [
            "=== Profilage 5D ===\n",
            "Volume: 26000 lignes\n",
            "Variables: 12 colonnes\n",
            "Relations: 2 relations\n",
            "Densité relationnelle: 0.67\n",
            "\n",
            "Recommandations:\n",
            "- compression_strategy: moderate\n",
            "- embedding_strategy: hierarchical\n",
            "- model_architecture: rht_with_pente\n",
            "- optimization_level: high\n"
          ]
        }
      ],
      "source": [
        "profiler = DimensionalProfiler()\n",
        "metrics = profiler.profile(data, relationships)\n",
        "\n",
        "print(\"=== Profilage 5D ===\")\n",
        "print(f\"Volume: {metrics.volume['total_rows']} lignes\")\n",
        "print(f\"Variables: {metrics.many_variables['total_columns']} colonnes\")\n",
        "print(f\"Relations: {metrics.many_tables['relationship_count']} relations\")\n",
        "print(f\"Densité relationnelle: {metrics.many_tables['relationship_density']:.2f}\")\n",
        "\n",
        "recommendations = profiler.recommend_pipeline()\n",
        "print(\"\\nRecommandations:\")\n",
        "for key, value in recommendations.items():\n",
        "    print(f\"- {key}: {value}\")"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
